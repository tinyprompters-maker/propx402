# PropX402 — Required Environment Variables
# Copy this file to .env and fill in your values

# Your Base mainnet wallet address (receives USDC payments)
WALLET_ADDRESS=0xYourBaseWalletAddress

# Anthropic API key — used for /property-narrative and /property-full
ANTHROPIC_API_KEY=sk-ant-...

# RentCast API key — property AVM, rent estimates
RENTCAST_API_KEY=your_rentcast_key_here

# FRED API key — economic/market data (free at fred.stlouisfed.org)
FRED_API_KEY=your_fred_key_here

# US Census API key — optional, raises rate limits (free at api.census.gov)
CENSUS_API_KEY=optional_for_higher_rate_limits

# Optional overrides
# PORT=3000
# PRICE_PER_QUERY=0.05
